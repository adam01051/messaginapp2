NODE_ENV=development
PORT=6001
CLIENT_ORIGIN=http://localhost:6002

# Use the provider's direct/session URL, not a transaction-pooler URL.
DATABASE_URL=postgresql://APP_USER:URL_ENCODED_PASSWORD@HOST:5432/messaging_app?schema=public&sslmode=require

# Optional: set this to a direct/session URL when DATABASE_URL is pooled.
# Prisma migrations use DIRECT_URL; the running application still uses DATABASE_URL.
DIRECT_URL=

JWT_SECRET=replace-with-a-long-random-secret

# Required together in production. Images are stored in Cloudinary, not locally.
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_KEY=your-api-key
CLOUDINARY_SECRET=your-api-secret

LOG_LEVEL=info
